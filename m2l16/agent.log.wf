update, run: python3 -m pip install --upgrade pip",\n  "exit_code": 0\n}\n\n\nYou ONLY have access to the following tools, and should NEVER make up tools that are not listed here:\n\nTool Name: localhost:8022_mcp_sandbox_execute_code\nTool Arguments: {\n  "properties": {\n    "code": {\n      "description": "",\n      "title": "Code",\n      "type": "string"\n    },\n    "language": {\n      "anyOf": [\n        {},\n        {\n          "type": "null"\n        }\n      ],\n      "default": null,\n      "description": "",\n      "title": "Language"\n    },\n    "timeout": {\n      "anyOf": [\n        {},\n        {\n          "type": "integer"\n        },\n        {\n          "type": "null"\n        }\n      ],\n      "default": null,\n      "description": "",\n      "title": "Timeout"\n    }\n  },\n  "required": [\n    "code",\n    "language",\n    "timeout"\n  ],\n  "title": "sandbox_execute_codeSchema",\n  "type": "object",\n  "additionalProperties": false\n}\nTool Description: Execute code in Python or JavaScript runtime.\n\n    Args:\n        code: Code to execute\n        language: Programming language (\'python\', \'javascript\')\n        timeout: Optional execution timeout in seconds\n\n    Returns:\n        Dict containing output, errors, and execution details\n    \nTool Name: localhost:8022_mcp_sandbox_file_operations\nTool Arguments: {\n  "properties": {\n    "action": {\n      "description": "",\n      "title": "Action",\n      "type": "string"\n    },\n    "path": {\n      "description": "",\n      "title": "Path",\n      "type": "string"\n    },\n    "content": {\n      "anyOf": [\n        {},\n        {\n          "type": "string"\n        },\n        {\n          "type": "null"\n        }\n      ],\n      "default": null,\n      "description": "",\n      "title": "Content"\n    },\n    "target": {\n      "anyOf": [\n        {},\n        {\n          "type": "string"\n        },\n        {\n          "type": "null"\n        }\n      ],\n      "defaul