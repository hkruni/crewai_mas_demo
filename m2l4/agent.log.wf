\\u8bf1\\u9975\\u3011\\u8bbe\\u8ba1\\u5177\\u4f53\\u7684\\u7b56\\u7565\\u6765\\u5f15\\u53d1\\u8bc4\\u8bba\\u4e92\\u52a8\\u3002\",\n      \"title\": \"Engagement Strategy\",\n      \"type\": \"string\"\n    },\n    \"retention_strategy\": {\n      \"description\": \"\\u3010\\u6536\\u85cf\\u8bf1\\u9975\\u3011\\u63d0\\u4f9b\\u5177\\u4f53\\u7684\\u5b9e\\u7528\\u4ef7\\u503c\\u8ba9\\u7528\\u6237\\u70b9\\u51fb\\u6536\\u85cf\\u3002\",\n      \"title\": \"Retention Strategy\",\n      \"type\": \"string\"\n    },\n    \"seo_keywords\": {\n      \"description\": \"\\u3010\\u5173\\u952e\\u8bcd\\u5e03\\u5c40\\u3011\\u57fa\\u4e8e KFS \\u7b56\\u7565\\uff0c\\u5217\\u51fa 3 \\u4e2a\\u5fc5\\u987b\\u57cb\\u5165\\u6587\\u6848\\u7684\\u957f\\u5c3e\\u5173\\u952e\\u8bcd\\u3002\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"title\": \"Seo Keywords\",\n      \"type\": \"array\"\n    }\n  },\n  \"required\": [\n    \"input_evaluation\",\n    \"target_audience_persona\",\n    \"core_pain_point\",\n    \"suggested_title\",\n    \"content_outline\",\n    \"engagement_strategy\",\n    \"retention_strategy\",\n    \"seo_keywords\"\n  ],\n  \"title\": \"ContentStrategyBrief\",\n  \"type\": \"object\",\n  \"additionalProperties\": false\n}\n\nDo not include the OpenAPI schema in the final output. Ensure the final output does not include any code block markers like ```json or ```python.\n\nBegin! This is VERY important to you, use the tools available and give your best Final Answer, your job depends on it!\n\nThought:"
